# ─────────────────────────────────────────────────────────────────────────────
# AgroVault — Environment Variables
# Copy this file to .env and fill in your values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=AgroVault
APP_VERSION=1.0.0
DEBUG=false

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING

# JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — good for single-server deployments up to ~50 concurrent users)
DATABASE_URL=sqlite:////app/data/agrovault.db

# PostgreSQL (recommended for production with multiple workers)
# DATABASE_URL=postgresql://agrovault_user:STRONG_PASSWORD@db:5432/agrovault

# ── CORS — allowed frontend origins ──────────────────────────────────────────
# In production, set this to your actual domain(s)
CORS_ORIGINS=["http://localhost","http://localhost:80","https://yourdomain.com"]

# ── Network ports ─────────────────────────────────────────────────────────────
APP_PORT=80
APP_PORT_SSL=443

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_SIZE_MB=20

# ── Optional: PostgreSQL service (uncomment if using postgres profile) ────────
# POSTGRES_DB=agrovault
# POSTGRES_USER=agrovault_user
# POSTGRES_PASSWORD=STRONG_PASSWORD
# POSTGRES_PORT=5432
